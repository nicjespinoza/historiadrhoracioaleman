      // --------------------------------------------------------
      // CONSULTS SUBCOLLECTION - CON SOFT DELETE
      // --------------------------------------------------------
      match /consults/{consultId} {
        // SEGURIDAD: Solo el propietario del paciente o usuarios privilegiados
